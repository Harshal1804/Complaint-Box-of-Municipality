<?xml version="1.0" encoding="utf-8"?>
<ScrollView android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="fill_parent"
        android:background="@drawable/insideimg"
        android:layout_height="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:orientation="vertical"
        tools:context=".MainActivity">
        <com.airbnb.lottie.LottieAnimationView
            android:layout_marginTop="5dp"
            android:layout_width="400dp"
            android:layout_marginLeft="-30dp"
            android:layout_height="200dp"
            app:lottie_autoPlay="true"
            android:id="@+id/l1"
            app:lottie_cacheComposition="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/searching"
            app:lottie_speed="1"
            >  </com.airbnb.lottie.LottieAnimationView>
        <TextView
            android:layout_marginTop="10dp"
            android:id="@+id/ReqId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textIsSelectable="true"
            android:textColor="@color/black"
            android:hint="Request Id"
            android:textSize="18dp" />
        <TextView
            android:layout_marginTop="10dp"
            android:id="@+id/showLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textIsSelectable="true"
            android:textColor="@color/black"
            android:hint="Location"
            android:textSize="18dp" />
        <TextView
            android:layout_marginTop="10dp"
            android:id="@+id/Dateee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/black"
            android:hint="Date"
            android:textSize="18dp" />
        <TextView
            android:id="@+id/storeNameEditText"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:layout_height="wrap_content"
            android:hint="Enter Your Name"/>

        <TextView
            android:id="@+id/mobileNoEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:textColor="@color/black"
            android:hint="Enter Mobile No"/>

        <TextView
            android:id="@+id/emailEditText"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:layout_height="wrap_content"
            android:hint="Enter Email id"/>
        <TextView
            android:id="@+id/pincode"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:layout_height="wrap_content"
            android:hint="Enter Pincode"/>


        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="800dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerCrop"
            android:layout_marginTop="16dp"/>
        <TextView
            android:id="@+id/Msg"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:layout_height="100dp"/>
        <TextView
            android:id="@+id/Review"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/C1"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:text="Change Review"
            android:layout_height="wrap_content"/>
        <ListView
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="200dp"/>

        <Button
            android:id="@+id/submitDataButton"
            android:text="Update"
            android:layout_width="match_parent"
            android:textColor="@color/black"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</ScrollView>